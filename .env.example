# ─── Database ───────────────────────────────────────────────────────────────
# Used by Docker Compose to create the MySQL container
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=taskmanager
MYSQL_USER=taskmanager_user
MYSQL_PASSWORD=taskmanager_pass

# ─── Backend (copy to backend/.env) ─────────────────────────────────────────
DATABASE_URL="mysql://taskmanager_user:taskmanager_pass@localhost:3306/taskmanager"
JWT_SECRET="change_me_to_a_long_random_secret"
JWT_EXPIRATION="1d"
PORT=3000

# ─── Frontend (copy to frontend/.env) ───────────────────────────────────────
VITE_API_BASE_URL="http://localhost:3000"
